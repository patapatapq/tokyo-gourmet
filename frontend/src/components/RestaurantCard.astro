---
import BudgetBadge from './BudgetBadge.astro';
import TravelInfo from './TravelInfo.astro';

interface Props {
  restaurant: {
    place_id: string;
    name: string;
    rating: number | null;
    user_rating_count: number;
    budget_tier: string;
    budget_label: string;
    budget_icon: string;
    budget_morning_lunch: { tier: string; label: string; icon: string };
    budget_dinner: { tier: string; label: string; icon: string };
    price_range: string;
    price_range_dinner: string;
    address: string;
    travel_time_minutes: number | null;
    travel_cost_yen: number | null;
    travel_summary: string;
    reservable: boolean | null;
    opening_hours: string[];
    photos: { filename: string; attribution: string }[];
    google_maps_url: string;
    website: string;
    phone: string;
    primary_type: string;
    genre: string;
    nearest_station: string;
    recommended_menu: string | null;
  };
  index: number;
}

const { restaurant: r, index } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<article class="glass-card rounded-[16px] overflow-hidden group">
  <!-- Photo Hero -->
  <div class="relative h-64 md:h-72 overflow-hidden">
    {r.photos.length > 0 ? (
      <img
        src={`${base}/photos/${r.photos[0].filename}`}
        alt={r.name}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full bg-white/5 flex items-center justify-center">
        <svg class="w-12 h-12 text-white/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
          <circle cx="12" cy="13" r="3"/>
        </svg>
      </div>
    )}

    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/92 via-black/20 to-transparent" aria-hidden="true"></div>

    <!-- Rank Badge -->
    <div class="absolute top-3 left-3">
      <span class="text-primary font-black text-2xl leading-none drop-shadow-lg">#{index}</span>
    </div>

    <!-- Genre Badge (top right) -->
    {r.genre && (
      <div class="absolute top-3 right-3">
        <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-black/55 text-white/90 backdrop-blur-sm border border-white/12">
          {r.genre}
        </span>
      </div>
    )}

    <!-- Name, Station & Rating (photo bottom overlay) -->
    <div class="absolute bottom-0 left-0 right-0 p-4">
      <div class="flex items-end justify-between gap-3">
        <div class="flex-1 min-w-0">
          <h3 class="text-white font-bold text-xl leading-tight">{r.name}</h3>
          {r.nearest_station && (
            <p class="text-white/60 text-xs mt-1 flex items-center gap-1">
              <svg class="w-3 h-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="7" width="20" height="14" rx="2"/>
                <path d="M16 2H8"/>
                <path d="M12 2v5"/>
                <path d="M6 17l-2 2"/>
                <path d="M18 17l2 2"/>
                <path d="M8 11h8"/>
                <path d="M8 15h2"/>
                <path d="M14 15h2"/>
              </svg>
              {r.nearest_station}
            </p>
          )}
        </div>
        {r.rating && (
          <div class="flex flex-col items-end shrink-0">
            <div class="flex items-center gap-1">
              <svg class="w-4 h-4 text-star" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              <span class="text-white font-bold text-lg leading-none">{r.rating}</span>
            </div>
            <span class="text-white/55 text-xs">{r.user_rating_count.toLocaleString()}件</span>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Body -->
  <div class="p-5 space-y-4">
    <!-- Budget -->
    <div class="flex flex-wrap gap-x-4 gap-y-1.5">
      <div class="flex items-center gap-1.5">
        <span class="text-xs text-text-light">昼</span>
        <BudgetBadge
          tier={r.budget_morning_lunch.tier}
          label={r.budget_morning_lunch.label}
          icon={r.budget_morning_lunch.icon}
        />
        <span class="text-xs text-text-muted">{r.price_range}</span>
      </div>
      <div class="flex items-center gap-1.5">
        <span class="text-xs text-text-light">夜</span>
        <BudgetBadge
          tier={r.budget_dinner.tier}
          label={r.budget_dinner.label}
          icon={r.budget_dinner.icon}
        />
        <span class="text-xs text-text-muted">{r.price_range_dinner}</span>
      </div>
    </div>

    <!-- Travel -->
    <TravelInfo
      minutes={r.travel_time_minutes}
      cost={r.travel_cost_yen}
      summary={r.travel_summary}
    />

    <!-- Address + Reservable -->
    <div class="space-y-2">
      <div class="flex items-start gap-2 text-text-muted">
        <svg class="w-4 h-4 mt-0.5 shrink-0 text-text-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        <span class="text-xs leading-relaxed">{r.address}</span>
      </div>

      {r.reservable !== null && (
        <div class="pl-6">
          <span class={`inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium border ${r.reservable ? 'bg-emerald-500/15 text-emerald-300 border-emerald-500/25' : 'bg-white/6 text-text-muted border-white/10'}`}>
            {r.reservable ? (
              <>
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.92 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
                予約可
              </>
            ) : (
              <>
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                </svg>
                当日OK
              </>
            )}
          </span>
        </div>
      )}
    </div>

    <!-- Recommended Menu (quote style — easier to read) -->
    {r.recommended_menu && (
      <div class="border-l-2 border-primary/45 pl-3 py-0.5">
        <p class="text-[11px] text-text-light font-medium mb-1 uppercase tracking-wide">口コミより</p>
        <p class="text-sm text-text-muted leading-relaxed">{r.recommended_menu}</p>
      </div>
    )}

    <!-- Opening Hours -->
    {r.opening_hours.length > 0 && (
      <details>
        <summary class="text-xs text-text-light cursor-pointer hover:text-white transition-colors flex items-center gap-1.5 list-none select-none">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          営業時間を確認
        </summary>
        <ul class="mt-2 text-xs text-text-muted space-y-1 pl-5">
          {r.opening_hours.map((h: string) => (
            <li>{h}</li>
          ))}
        </ul>
      </details>
    )}

    <!-- Actions -->
    <div class="flex gap-2 pt-1">
      <a
        href={r.google_maps_url}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 text-center py-2.5 px-4 bg-primary hover:bg-primary-dark text-white rounded-[12px] text-sm font-medium transition-colors no-underline cursor-pointer"
      >
        地図を開く
      </a>
      {r.website && (
        <a
          href={r.website}
          target="_blank"
          rel="noopener noreferrer"
          class="py-2.5 px-4 border border-white/15 text-text-muted hover:text-white hover:bg-white/10 rounded-[12px] text-sm transition-colors no-underline cursor-pointer"
        >
          公式サイト
        </a>
      )}
    </div>
  </div>
</article>
