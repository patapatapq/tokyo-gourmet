---
import BudgetBadge from './BudgetBadge.astro';
import TravelInfo from './TravelInfo.astro';

interface Props {
  restaurant: {
    place_id: string;
    name: string;
    rating: number | null;
    user_rating_count: number;
    budget_tier: string;
    budget_label: string;
    budget_icon: string;
    budget_morning_lunch: { tier: string; label: string; icon: string };
    budget_dinner: { tier: string; label: string; icon: string };
    price_range: string;
    price_range_dinner: string;
    address: string;
    travel_time_minutes: number | null;
    travel_cost_yen: number | null;
    travel_summary: string;
    reservable: boolean | null;
    opening_hours: string[];
    photos: { filename: string; attribution: string }[];
    google_maps_url: string;
    website: string;
    phone: string;
    primary_type: string;
    genre: string;
    nearest_station: string;
    recommended_menu: string | null;
    recommended_menu_rating?: number | null;
    payment_methods?: {
      credit_card: boolean | null;
      debit_card: boolean | null;
      cash_only: boolean | null;
      nfc: boolean | null;
    } | null;
  };
  index: number;
}

const { restaurant: r, index } = Astro.props;
const base = import.meta.env.BASE_URL;

// 住所から先頭の「日本、」「日本, 」を除去
const cleanAddress = r.address.replace(/^日本[、,，]\s*/, '');

// 写真
const hasQuadPhotos = r.photos.length >= 4;
const hasMultiplePhotos = !hasQuadPhotos && r.photos.length >= 2;

// 営業時間：土日のみ抽出
const weekendHours = r.opening_hours.filter((h: string) => /^(土曜日|日曜日)/.test(h));
const hasExpandableHours = r.opening_hours.length > 0 && r.opening_hours.some((h: string) => /^(月曜日|火曜日|水曜日|木曜日|金曜日)/.test(h));

// 営業時間文字列を整形: "土曜日: 8時00分～16時30分" → "土曜日 8:00 - 16:30"
function formatHours(h: string): string {
  return h
    .replace(/^(\S+?): /, '$1 ')                                    // 曜日後のコロン除去
    .replace(/[月火水木金土日]曜日/g, (m) => m[0])                 // 月曜日→月, 土曜日→土 etc.
    .replace(/(\d+)時(\d+)分/g, (_, hh, mm) => `${+hh}:${mm}`)   // h:mm形式
    .replace(/～/g, ' - ');                                         // ～ → -
}
---

<article class="glass-card rounded-[16px] overflow-hidden group">
  <!-- Photo Hero -->
  <div class="relative h-64 md:h-72 overflow-hidden">

    {hasQuadPhotos ? (
      <!-- 4分割: 左列(外観+内装) / 中(料理1) / 右(料理2) -->
      <div class="flex h-full gap-px">

        <!-- 左列: 外観(上) + 内装(下) -->
        <div class="relative flex flex-col flex-1 gap-px">
          <div class="relative flex-1 overflow-hidden">
            <img
              src={`${base}/photos/${r.photos[0].filename}`}
              alt={`${r.name} 外観`}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/50" aria-hidden="true"></div>
          </div>
          <div class="relative flex-1 overflow-hidden">
            <img
              src={`${base}/photos/${r.photos[1].filename}`}
              alt={`${r.name} 内装`}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent" aria-hidden="true"></div>
          </div>
        </div>

        <!-- 中: 料理1 -->
        <div class="relative flex-1 overflow-hidden">
          <img
            src={`${base}/photos/${r.photos[2].filename}`}
            alt={`${r.name} 料理1`}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-transparent to-transparent" aria-hidden="true"></div>
        </div>

        <!-- 右: 料理2 -->
        <div class="relative flex-1 overflow-hidden">
          <img
            src={`${base}/photos/${r.photos[3].filename}`}
            alt={`${r.name} 料理2`}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-transparent to-transparent" aria-hidden="true"></div>
        </div>

      </div>
    ) : hasMultiplePhotos ? (
      <!-- 2分割: 外観(左) + 料理(右) -->
      <div class="flex h-full gap-px">
        <div class="relative flex-[3] overflow-hidden">
          <img
            src={`${base}/photos/${r.photos[0].filename}`}
            alt={r.name}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/92 via-black/20 to-transparent" aria-hidden="true"></div>
        </div>
        <div class="relative flex-[2] overflow-hidden">
          <img
            src={`${base}/photos/${r.photos[1].filename}`}
            alt={`${r.name} 料理`}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/10 to-black/20" aria-hidden="true"></div>
        </div>
      </div>
    ) : (
      <!-- 1枚: フルwidth -->
      <>
        {r.photos.length > 0 ? (
          <img
            src={`${base}/photos/${r.photos[0].filename}`}
            alt={r.name}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
        ) : (
          <div class="w-full h-full bg-white/5 flex items-center justify-center">
            <svg class="w-12 h-12 text-white/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
              <circle cx="12" cy="13" r="3"/>
            </svg>
          </div>
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-black/92 via-black/20 to-transparent" aria-hidden="true"></div>
      </>
    )}

    <!-- Rank Badge (常に左上) -->
    <div class="absolute top-3 left-3">
      <span class="font-black text-2xl leading-none text-primary rounded-lg px-1.5 py-0.5 bg-black/60 backdrop-blur-sm">
        #{index}
      </span>
    </div>

    <!-- 4分割レイアウト用: 全幅グラデーション -->
    {hasQuadPhotos && (
      <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-black/80 to-transparent pointer-events-none" aria-hidden="true"></div>
    )}

    <!-- ジャンル＋店名オーバーレイ: 全レイアウト共通 -->
    <div class="absolute bottom-0 left-0 right-0 p-4" style={hasMultiplePhotos ? 'right: 40%;' : ''}>
      {r.genre && (
        <div class="text-xs text-white/70 mb-1 drop-shadow">{r.genre}</div>
      )}
      <h3 class="text-white font-bold text-xl leading-tight truncate drop-shadow">{r.name}</h3>
    </div>
  </div>

  <!-- Body -->
  <div class="p-5 space-y-3">

    <!-- ★ 評価 -->
    {r.rating && (
      <div class="flex items-center gap-3">
        <svg class="w-4 h-4 shrink-0 text-star" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        <div class="flex items-baseline gap-1.5">
          <span class="font-bold text-white text-lg leading-none">{r.rating}</span>
          <span class="text-text-light text-xs">{r.user_rating_count.toLocaleString()}件</span>
        </div>
      </div>
    )}

    <!-- ¥ 予算 -->
    <div class="flex items-start gap-3">
      <span class="w-4 shrink-0 text-center text-text-light text-sm mt-0.5 leading-none">¥</span>
      <div class="flex flex-wrap gap-x-5 gap-y-1">
        <div class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-yellow-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-label="昼">
            <circle cx="12" cy="12" r="4"/>
            <line x1="12" y1="2" x2="12" y2="6"/>
            <line x1="12" y1="18" x2="12" y2="22"/>
            <line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/>
            <line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/>
            <line x1="2" y1="12" x2="6" y2="12"/>
            <line x1="18" y1="12" x2="22" y2="12"/>
            <line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/>
            <line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/>
          </svg>
          <span class="text-xs font-bold text-white">{r.budget_morning_lunch.label}</span>
          <span class="text-xs text-text-muted">{r.price_range}</span>
        </div>
        <div class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-blue-300 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-label="夜">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <span class="text-xs font-bold text-white">{r.budget_dinner.label}</span>
          <span class="text-xs text-text-muted">{r.price_range_dinner}</span>
        </div>
      </div>
    </div>

    <!-- 🚃 最寄り・移動 -->
    <TravelInfo
      minutes={r.travel_time_minutes}
      cost={r.travel_cost_yen}
      summary={r.travel_summary}
      nearest_station={r.nearest_station}
    />

    <!-- バッジ行: 決済方法 -->
    {r.payment_methods && (
      <div class="flex flex-wrap gap-1.5 pl-7">
        {r.payment_methods?.credit_card && (
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs bg-indigo-500/15 text-indigo-300 border border-indigo-500/25">
            💳 クレジットカード
          </span>
        )}
        {r.payment_methods?.nfc && (
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs bg-purple-500/15 text-purple-300 border border-purple-500/25">
            📱 電子マネー
          </span>
        )}
        {r.payment_methods?.cash_only && (
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs bg-amber-500/15 text-amber-300 border border-amber-500/25">
            💴 現金のみ
          </span>
        )}
      </div>
    )}

    <!-- | 口コミ -->
    {r.recommended_menu && (
      <div class="border-l-2 border-primary/45 pl-3 py-0.5">
        <div class="flex items-center gap-2 mb-1">
          <p class="text-[11px] text-text-light font-medium uppercase tracking-wide">口コミより</p>
          {r.recommended_menu_rating && (
            <span class="text-star text-xs font-bold">{"★".repeat(r.recommended_menu_rating)}</span>
          )}
        </div>
        <p class="text-xs text-text-muted leading-relaxed">{r.recommended_menu}</p>
      </div>
    )}

    <!-- 🕐 営業時間 -->
    {r.opening_hours.length > 0 && (
      <div class="flex items-start gap-3">
        <svg class="w-4 h-4 shrink-0 text-text-light mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        <div class="flex-1">
          {weekendHours.length > 0 && (
            <div class="flex flex-wrap gap-x-4 gap-y-0.5 text-xs text-text-muted">
              {weekendHours.map((h: string) => <span>{formatHours(h)}</span>)}
            </div>
          )}
          {(hasExpandableHours || (weekendHours.length === 0 && r.opening_hours.length > 0)) && (
            <details class="hours-details mt-1">
              <summary class="text-xs text-text-light cursor-pointer hover:text-white transition-colors inline-flex items-center gap-1 list-none select-none">
                <svg class="w-3 h-3 chevron-icon transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
                {weekendHours.length > 0 ? '平日の営業時間を確認' : '営業時間を確認'}
              </summary>
              <ul class="mt-1.5 text-xs text-text-muted space-y-0.5 pl-4">
                {r.opening_hours.map((h: string) => (
                  <li>{formatHours(h)}</li>
                ))}
              </ul>
            </details>
          )}
        </div>
      </div>
    )}

    <!-- Actions -->
    <div class="flex gap-2 pt-1">
      <a
        href={r.google_maps_url}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 text-center py-2.5 px-4 bg-primary hover:bg-primary-dark text-white rounded-[12px] text-sm font-medium transition-colors no-underline cursor-pointer"
      >
        地図を開く
      </a>
      {r.website && (
        <a
          href={r.website}
          target="_blank"
          rel="noopener noreferrer"
          class="py-2.5 px-4 border border-white/15 text-text-muted hover:text-white hover:bg-white/10 rounded-[12px] text-sm transition-colors no-underline cursor-pointer"
        >
          公式サイト
        </a>
      )}
    </div>
  </div>
</article>
