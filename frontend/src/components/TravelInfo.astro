---
interface Props {
  minutes: number | null;
  cost: number | null;
  summary: string;
  nearest_station: string;
}

const { minutes, cost, summary, nearest_station } = Astro.props;
---

<div class="flex items-start gap-2 text-sm text-text-muted">
  <svg class="w-4 h-4 mt-0.5 shrink-0 text-text-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect width="16" height="16" x="4" y="3" rx="2"/>
    <path d="M4 11h16"/>
    <path d="M12 3v8"/>
    <path d="m8 19-2 3"/>
    <path d="m18 22-2-3"/>
    <path d="M8 15h0"/>
    <path d="M16 15h0"/>
  </svg>
  <div class="flex-1">
    {nearest_station && (
      <div class="font-medium text-white/90 text-sm leading-snug mb-0.5">
        最寄り駅：{nearest_station}
      </div>
    )}
    <div>
      {minutes !== null ? (
        <span class="font-medium text-white">{minutes}分</span>
      ) : (
        <span class="text-text-light">—</span>
      )}
      {cost !== null && (
        <span class="ml-1 text-text-muted">/ ¥{cost.toLocaleString()}</span>
      )}
    </div>
    {summary && (
      <div class="text-xs text-text-light mt-0.5">{summary}</div>
    )}
  </div>
</div>
