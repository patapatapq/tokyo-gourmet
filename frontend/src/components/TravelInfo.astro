---
interface Props {
  minutes: number | null;
  cost: number | null;
  summary: string;
  nearest_station: string;
}

const { minutes, cost, summary, nearest_station } = Astro.props;

const displayStation = nearest_station
  .replace(/駅（/, '（')
  .replace(/駅$/, '');

// サマリーから時間部分を除去して末尾に表示（例: "公共交通機関（7km）"）
const compactSummary = summary
  .replace(/約?\s*\d+分\s*/, '')
  .trim();
---

<div class="flex items-start gap-3">
  <svg class="w-4 h-4 shrink-0 text-text-light mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect width="16" height="16" x="4" y="3" rx="2"/>
    <path d="M4 11h16"/>
    <path d="M12 3v8"/>
    <path d="m8 19-2 3"/>
    <path d="m18 22-2-3"/>
    <path d="M8 15h0"/>
    <path d="M16 15h0"/>
  </svg>
  <div class="flex items-baseline gap-2 flex-wrap">
    {displayStation && (
      <span class="font-bold text-white text-sm">{displayStation}</span>
    )}
    {minutes !== null && (
      <span class="font-bold text-white text-sm">{minutes}分</span>
    )}
    {cost !== null && cost > 0 && (
      <span class="text-text-muted text-xs">¥{cost.toLocaleString()}</span>
    )}
    {compactSummary && (
      <span class="text-text-light text-xs">{compactSummary}</span>
    )}
  </div>
</div>
